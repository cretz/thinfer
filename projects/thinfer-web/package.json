{
  "name": "thinfer",
  "version": "0.0.0",
  "private": true,
  "description": "WebGPU inference engine, browser bindings.",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#wasm": "./pkg/thinfer_web.js"
  },
  "files": [
    "dist",
    "pkg"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm build:wasm && pnpm build:ts",
    "build:wasm": "cargo build --release --target wasm32-unknown-unknown -p thinfer-web && wasm-bindgen --target web --out-dir pkg ../target/wasm32-unknown-unknown/release/thinfer_web.wasm",
    "build:ts": "tsc -p tsconfig.build.json && node scripts/resolve-wasm-import.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ scripts/ examples/",
    "fmt": "oxfmt --write src/ scripts/ examples/",
    "fmt:check": "oxfmt --check src/ scripts/ examples/",
    "example:gen-image": "node examples/gen-image/serve.ts",
    "playwright:install": "playwright install chromium",
    "test:web": "pnpm playwright:install && node scripts/test.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "chromedriver": "^147.0.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.50.0",
    "typescript": "^6.0.2"
  }
}
